# Database — PostgreSQL (Production)
# Replace USER, PASSWORD, HOST, PORT, DATABASE with your actual values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Direct URL — only needed when using Prisma Accelerator or connection pooler (PgBouncer).
# For standard Hostinger Node.js deployment, this is optional.
# If your hosting uses a direct connection, omit or set same as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Authentication
JWT_SECRET="replace-with-strong-random-secret"

# App
NEXT_PUBLIC_APP_NAME="AZM Flow"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Environment
NODE_ENV="production"
